{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adjudicator output (one disputed report-slot mark)",
  "type": "object",
  "required": ["hit", "evidence"],
  "additionalProperties": false,
  "properties": {
    "hit": {"type": "boolean"},
    "evidence": {
      "type": "string",
      "description": "Verbatim quote from the disputed report that satisfies the expectation; empty string when hit is false."
    }
  }
}
